# RentFlow MVP .gitignore
# Protects sensitive configuration files and excludes build artifacts

# Sensitive Configuration Files (DO NOT COMMIT!)
# Contains API keys, database credentials, and other secrets
js/config.js
js/config-local.js
js/config-production.js
supabase-credentials.txt
.env
.env.local
.env.development
.env.production

# Node.js Dependencies (if using Node.js tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build Outputs & Dist Files
dist/
build/
*.min.js
*.min.css
bundle.js
bundle.css

# IDE & Editor Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary Files
*.tmp
*.temp
*.log
coverage/
.nyc_output/

# Cache Directories
.cache/
.temp/
.tmp/

# Lock Files (can be committed if you want reproducible builds)
package-lock.json
yarn.lock
npm-shrinkwrap.json

# Runtime Data
pids/
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env.test

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Backup Files
backup files/